# Copy to .env and edit before `docker compose up -d`

HTTP_PORT=8080

# Database (created automatically inside the db container; the app and
# cron containers receive these too, so the wizard never asks for them)
DB_NAME=ssanta
DB_USER=ssanta
DB_PASS=change-me
DB_ROOT_PASS=change-me-too

# SMTP (optional here — leave SMTP_HOST empty to enter it in the web wizard
# instead). Use a host reachable FROM THE CONTAINER, not "localhost".
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Secret Santa

# Optional: public base URL used in reveal emails, e.g. https://santa.example.com
# Auto-detected during the wizard if left empty.
SITE_URL=

# Max selfie photo size in MB (photos are downscaled server-side; PHP accepts up to 40M)
PHOTO_MAX_MB=30

# How many days participants stay logged in (admin re-auth is always 2h)
SESSION_DAYS=15

# Container timezone — must match how you enter event dates/times.
# Wrong value = reveals firing an hour early or late during BST.
TZ=Europe/London
